<VirtualHost *:80>
    ServerName localhost
    DocumentRoot {{ drupal_install_dir }}

    <Directory {{ drupal_install_dir }}>
        AllowOverride All
        Require all granted
    </Directory>

    ErrorLog /var/log/apache2/drupal_error.log
    CustomLog /var/log/apache2/drupal_access.log combined
</VirtualHost>